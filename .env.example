# ===== SERVER =====
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ===== DATABASE =====
DATABASE_URL="postgresql://flexpay:securepass@localhost:5432/flexpay?schema=public"

# ===== REDIS =====
REDIS_URL="redis://localhost:6379"
REDIS_OTP_TTL=300
REDIS_RATE_LIMIT_TTL=3600

# ===== JWT =====
JWT_ACCESS_SECRET="your-super-secret-access-key-change-in-prod-min-32-chars"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-prod-min-32-chars"
JWT_REFRESH_EXPIRY=7d

# ===== TWILIO =====
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"

# ===== NYMCARD =====
NYMCARD_API_KEY="nym_live_xxxxxxxxxxxxxxxxxxxx"
NYMCARD_API_BASE="https://api.nymcard.com/v1"
NYMCARD_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ===== MONEYHASH =====
MONEYHASH_API_KEY="mh_live_xxxxxxxxxxxxxxxxxxxx"
MONEYHASH_API_BASE="https://api.moneyhash.com/v1"
MONEYHASH_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ===== FLEXXPAY =====
FLEXXPAY_API_KEY="fp_live_xxxxxxxxxxxxxxxxxxxx"
FLEXXPAY_API_BASE="https://api.flexxpay.com/v1"
FLEXXPAY_REDIRECT_URL="https://flexpay.ae/ewa/success"

# ===== FIREBASE =====
FIREBASE_PROJECT_ID="flexpay-prod"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@flexpay-prod.iam.gserviceaccount.com"

# ===== SECURITY =====
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_SIGNATURE_HEADER="x-nymcard-signature"

# ===== APP =====
APP_NAME="FlexPay"
APP_URL="https://api.flexpay.ae"
SUPPORT_EMAIL="support@flexpay.ae"
CASHBACK_BASIC_RATE=0.01
CASHBACK_LUXURY_RATE=0.025
CASHBACK_BASIC_CAP=100
CASHBACK_LUXURY_CAP=300
PHYSICAL_CARD_FEE=30
P2P_TRANSFER_FEE=2
REMITTANCE_FX_SPREAD=0.005
REMITTANCE_FEE_PERCENT=0.006
