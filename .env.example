# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://flexpay:flexpay@localhost:5432/flexpay?schema=public"

# Redis (used for OTP store + Bull queues)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Twilio (SMS / OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555550100

# NymCard
NYMCARD_BASE_URL=https://sandbox.nymcard.com/api
NYMCARD_API_KEY=

# Firebase (push notifications)
GOOGLE_APPLICATION_CREDENTIALS=

# MoneyHash (remittance)
MONEYHASH_BASE_URL=https://sandbox.moneyhash.io/api
MONEYHASH_API_KEY=

# FlexxPay (EWA partner)
FLEXXPAY_BASE_URL=https://sandbox.flexxpay.com/api
FLEXXPAY_API_KEY=

# Webhook signature secret (NymCard)
NYMCARD_WEBHOOK_SECRET=
