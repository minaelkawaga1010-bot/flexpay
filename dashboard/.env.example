# Server
NODE_ENV=development

# Local Prisma (SQLite by default; switch to postgres for prod-parity)
DATABASE_URL="file:./prisma/dev.db"

# JWT secrets — generate with `openssl rand -hex 32`
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Optional: proxy overlap routes (wallet/cards/payroll) through the Express backend
# instead of the dashboard's own Prisma. Leave blank to run fully standalone.
BACKEND_API_URL=http://localhost:3000/api/v1

# NymCard sandbox (only needed if exercising card flows via this surface)
NYMCARD_API_KEY=
NYMCARD_API_BASE=https://sandbox.nymcard.com/v1
NYMCARD_WEBHOOK_SECRET=
