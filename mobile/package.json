{
  "name": "flexpay-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "test:e2e:build": "detox build --configuration ios.sim.debug",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules ios/Pods ios/build android/build android/app/build",
    "pod-install": "cd ios && pod install && cd ..",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:submit:ios": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "^3.29.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-reanimated": "^3.6.2",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@tanstack/react-query": "^5.17.19",
    "axios": "^1.6.7",
    "zod": "^3.22.4",
    "zustand": "^4.5.0",
    "immer": "^10.0.3",
    "react-native-keychain": "^8.1.2",
    "react-native-biometrics": "^3.0.1",
    "react-native-encrypted-storage": "^4.0.3",
    "@react-native-firebase/app": "^18.7.3",
    "@react-native-firebase/messaging": "^18.7.3",
    "@notifee/react-native": "^7.8.2",
    "react-native-svg": "^14.1.0",
    "react-native-linear-gradient": "^2.8.3",
    "lottie-react-native": "^6.5.1",
    "react-native-vector-icons": "^10.0.3",
    "react-native-localize": "^3.0.6",
    "i18next": "^23.7.16",
    "react-i18next": "^14.0.0",
    "date-fns": "^3.3.1",
    "numeral": "^2.0.6",
    "uuid": "^9.0.1",
    "react-native-get-random-values": "^1.10.0",
    "react-native-haptic-feedback": "^2.2.0",
    "@sentry/react-native": "^5.24.1",
    "@amplitude/analytics-react-native": "^1.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/runtime": "^7.23.9",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.5",
    "@types/jest": "^29.5.12",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.2.48",
    "@types/react-test-renderer": "^18.0.7",
    "@types/uuid": "^9.0.8",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "react-test-renderer": "18.2.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "detox": "^20.17.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
