{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@screens/*": ["screens/*"],
      "@navigation/*": ["navigation/*"],
      "@services/*": ["services/*"],
      "@store/*": ["store/*"],
      "@hooks/*": ["hooks/*"],
      "@theme": ["theme"],
      "@theme/*": ["theme/*"],
      "@config/*": ["config/*"],
      "@i18n/*": ["i18n/*"]
    }
  },
  "include": ["src/**/*", "App.tsx", "__tests__/**/*"],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "jest.config.js", "e2e/**/*"]
}
